# Copy to `.env` and edit to fit your environment.
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.railway.app,.fly.dev

# DATABASE_URL is optional. If unset, a local SQLite file is used.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Comma-separated list of origins allowed to call the API (frontend URLs).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# You must provide a descriptive User-Agent per Nominatim's usage policy.
USER_AGENT=ELDTripPlanner/1.0 (https://your-site; your-email@example.com)

# OSRM public demo server (rate limited). Self-host or swap for prod.
OSRM_BASE_URL=https://router.project-osrm.org
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
